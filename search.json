---
layout: null
---
[
{% assign items = site.pages | concat: site.posts %}
{% for item in items %}
  {% if item.title and item.url %}
  {
    "title": "{{ item.title | escape }}",
    "url": "{{ site.baseurl }}{{ item.url }}",
    "content": "{{ item.content | strip_html | strip_newlines | escape }}"
  }{% unless forloop.last %},{% endunless %}
  {% endif %}
{% endfor %}
]
